{
  "BrowserRuntime": {
    "MaxConcurrentSessions": 2,
    "Headless": true,
    "AllowHttpForDevelopment": false,
    "ScreenshotQuality": 72
  },
  "ViewportStreaming": {
    "FramesPerSecond": 5,
    "LowBandwidthFramesPerSecond": 2,
    "MaxFrameBytes": 2500000
  },
  "WorkerSecurity": {
    "AllowedOrigins": [
      "http://127.0.0.1:5173",
      "http://localhost:5173"
    ]
  },
  "ApplyFillApi": {
    "BaseUri": "http://127.0.0.1:5180"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Playwright": "Warning"
    }
  }
}
