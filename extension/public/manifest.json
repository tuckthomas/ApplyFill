{
  "manifest_version": 3,
  "name": "ApplyFill Local Autofill",
  "description": "Reviews and fills user-approved application fields on the active tab without submitting the form.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Review fields with ApplyFill",
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": [
      "https://applyfill.app/*",
      "https://www.applyfill.app/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "incognito": "not_allowed",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'; frame-ancestors 'none'"
  }
}
